{
  "name": "cybersecurity-ai-mcp",
  "description": "Cybersecurity Ai MCP server. Tools: classify vulnerability, lookup cve, check security headers. Built by MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "classify_vulnerability",
      "description": "Classify a vulnerability by type, severity, and OWASP category.",
      "parameters": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "affected_component": {
            "type": "string"
          },
          "has_exploit": {
            "type": "boolean"
          },
          "network_accessible": {
            "type": "boolean"
          },
          "auth_required": {
            "type": "boolean"
          }
        },
        "required": [
          "description"
        ]
      }
    },
    {
      "name": "lookup_cve",
      "description": "Look up CVE details from the vulnerability database.",
      "parameters": {
        "type": "object",
        "properties": {
          "cve_id": {
            "type": "string"
          },
          "product": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "check_security_headers",
      "description": "Analyze HTTP security headers against best practices.",
      "parameters": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "object"
          }
        },
        "required": [
          "headers"
        ]
      }
    },
    {
      "name": "analyze_password_strength",
      "description": "Analyze password strength and provide improvement suggestions.",
      "parameters": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          }
        },
        "required": [
          "password"
        ]
      }
    },
    {
      "name": "generate_threat_model",
      "description": "Generate a STRIDE-based threat model for a system.",
      "parameters": {
        "type": "object",
        "properties": {
          "system_name": {
            "type": "string"
          },
          "components": {
            "type": "array"
          },
          "data_types": {
            "type": "array"
          },
          "external_interfaces": {
            "type": "array"
          },
          "authentication_method": {
            "type": "string"
          },
          "deployment": {
            "type": "string"
          }
        },
        "required": [
          "system_name",
          "components",
          "data_types"
        ]
      }
    }
  ]
}